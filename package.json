{
  "name": "microlearning-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Microlearning Classroom LMS Platform",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11.9.0 <12"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace @microlearning/web",
    "dev:api": "npm run dev --workspace @microlearning/api",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "verify:negative-gate": "node scripts/verify-negative-lint-gate.mjs",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run lint && npm run verify:negative-gate && npm run format:check && npm run typecheck && npm run test && npm run build",
    "check:ci": "npm run lint && npm run verify:negative-gate && npm run format:check && npm run typecheck && npm run test:coverage && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
