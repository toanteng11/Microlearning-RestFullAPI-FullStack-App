# API runtime
APP_ENV=development
APP_VERSION=0.1.0
COMMIT_SHA=local
BUILD_TIME=local
PORT=4000
MONGODB_URI=mongodb://localhost:27017/microlearning
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# Web build-time public configuration. Never put secrets in VITE_* values.
VITE_API_BASE_URL=http://localhost:4000
